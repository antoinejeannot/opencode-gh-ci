{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-gh-ci",
  "version": "0.1.0",
  "type": "module",
  "description": "GitHub Actions CI status in the OpenCode sidebar with live elapsed timers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/antoinejeannot/opencode-gh-ci"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opencode-tui-plugin",
    "github",
    "actions",
    "ci",
    "sidebar"
  ],
  "exports": {
    "./server": {
      "import": "./server.ts"
    },
    "./tui": {
      "import": "./tui.tsx"
    }
  },
  "files": [
    "server.ts",
    "tui.tsx",
    "shared.ts",
    "README.md"
  ],
  "engines": {
    "opencode": ">=1.3.13"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
